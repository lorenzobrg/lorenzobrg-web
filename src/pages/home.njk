---
layout: layouts/base.njk
pagination:
  data: locales
  size: 1
  alias: lang
permalink: /{{ lang }}/
eleventyComputed:
  title: "{{ translations[lang].home }}"
  description: "{{ translations[lang].homeDescription }}"
---

{% set homeTitle = (profile.about[lang] and profile.about[lang].title) or site.handle %}
<h1>{{ homeTitle }}</h1>

<p>{{ translations[lang].aboutIntro }}</p>

<p>
  {{ translations[lang].contactEmail }}: <a href="mailto:info@lorenzoborghi.it">info@lorenzoborghi.it</a>
</p>

<h2>{{ translations[lang].homeLatestPostsTitle }} <a href="/{{ lang }}/articles/feed.xml">{{ translations[lang].rssFeed }}</a></h2>

<ul>
  {% for post in (collections["articles_" + lang].slice(0, 5)) %}
    <li><a href="{{ post.url }}">{{ post.data.title }}</a>{% if post.date %} {{ translations[lang].dateOn }} {{ post.date.toISOString().slice(0,10) }}{% endif %}</li>
  {% endfor %}
</ul>

<p><a href="{{ "/posts/" | locale_url }}">{{ translations[lang].ctaAllPosts }}</a></p>

<h2>{{ translations[lang].homeLatestPublicationsTitle }}</h2>

<ul>
  {% set pubs = collections["publications_" + lang] or [] %}
  {% for pub in (pubs.slice(0, 5)) %}
    <li><a href="{{ pub.url }}">{{ pub.data.title }}</a>{% if pub.date %} {{ translations[lang].dateOn }} {{ pub.date.toISOString().slice(0,10) }}{% endif %}</li>
  {% endfor %}
</ul>

<p><a href="{{ "/publications/" | locale_url }}">{{ translations[lang].ctaAllPublications }}</a></p>
