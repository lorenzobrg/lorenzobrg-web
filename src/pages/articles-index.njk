---
layout: layouts/base.njk
pagination:
  data: locales
  size: 1
  alias: lang
permalink: /{{ lang }}/articles/
eleventyComputed:
  title: "{{ translations[lang].articles }}"
  description: "{{ translations[lang].articlesDescription }}"
---

<h2>{{ translations[lang].articles }}</h2>

{% for post in collections["articles_" + lang] %}
  <article>
    <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
    <small>{{ post.date.toISOString().slice(0,10) }}</small>
    <p>{{ post.data.description }}</p>
  </article>
{% endfor %}
