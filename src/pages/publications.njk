---
layout: layouts/base.njk
pagination:
  data: locales
  size: 1
  alias: lang
permalink: /{{ lang }}/publications/
eleventyComputed:
  title: "{{ translations[lang].publicationsTitle }}"
  description: "{{ translations[lang].publicationsDescription }}"
---

<h1 id="publications">{{ translations[lang].publicationsTitle }}</h1>

<p>{{ translations[lang].publicationsIntro }}</p>

<ul>
  {% set pubs = collections["publications_" + lang] or [] %}
  {% for pub in pubs %}
    <li><a href="{{ pub.url }}">{{ pub.data.title }}</a>{% if pub.date %} {{ translations[lang].dateOn }} {{ pub.date.toISOString().slice(0,10) }}{% endif %}</li>
  {% endfor %}
</ul>
