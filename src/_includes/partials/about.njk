{% set about = profile.about[lang] %}

{% if about %}
  <div class="about__heading">
    {% if about.logo %}<span class="about__logo" role="img">{{ about.logo }}</span>{% endif %}
    {% if about.logo_image %}<img class="about__logo" src="{{ about.logo_image }}" alt="{{ about.logo_alt or 'Logo' }}">{% endif %}
    <h2 class="about__title">{{ about.title }}</h2>
  </div>
  {% if about.description %}<p class="about__description">{{ about.description }}</p>{% endif %}

  {% from "partials/icons.njk" import icon %}
  {% set socials = profile.socialLinks[lang] or [] %}
  {% if socials | length %}
    <ul class="aside__social-links" aria-label="{{ translations[lang].linksTitle }}">
      {% for s in socials %}
        <li>
          {% set isExternal = s.url and (s.url.indexOf('http') == 0) %}
          {% set rel = "me nofollow noopener noreferrer" if isExternal else "" %}
          <a class="social-link" href="{{ s.url }}"{% if rel %} rel="{{ rel }}"{% endif %} target="_blank" aria-label="{{ s.title }}" title="{{ s.title }}">
            {{ icon(s.icon) | safe }}
            <span class="sr-only">{{ s.title }}</span>
          </a>
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  <div class="theme-picker">
    <label class="theme-picker__label" for="theme-picker">{{ translations[lang].themeToggle }}</label>
    <select class="theme-picker__select" id="theme-picker" name="palette" aria-label="{{ translations[lang].themeToggle }}"></select>
  </div>
{% endif %}
