{% set about = profile.about[lang] %}

{% if about %}
  <div class="about__heading">
    {% if about.logo %}<span class="about__logo" role="img">{{ about.logo }}</span>{% endif %}
    {% if about.logo_image %}<img class="about__logo" src="{{ about.logo_image }}" alt="{{ about.logo_alt or 'Logo' }}">{% endif %}
    <h1 class="about__title">{{ about.title }}</h1>
  </div>
  {% if about.description %}<p class="about__description">{{ about.description }}</p>{% endif %}

  {% from "partials/icons.njk" import icon %}
  {% set socials = profile.socialLinks[lang] or [] %}
  {% if socials | length %}
    <ul class="aside__social-links" aria-label="{{ translations[lang].linksTitle }}">
      {% for s in socials %}
        <li>
          <a class="social-link" href="{{ s.url }}" rel="me noopener" target="_blank" aria-label="{{ s.title }}" title="{{ s.title }}">
            {{ icon(s.icon) | safe }}
            <span class="sr-only">{{ s.title }}</span>
          </a>
        </li>
      {% endfor %}
    </ul>
  {% endif %}
{% endif %}
