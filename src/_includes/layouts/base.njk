<!doctype html>
<html lang="{{ lang }}">
    <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>

        <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/favicon/apple-touch-icon.png"/>
        <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon/favicon-32x32.png"/>
        <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon/favicon-16x16.png"/>
        <link rel="icon" href="/assets/images/favicon/favicon.ico"/>
        <link rel="manifest" href="/assets/images/favicon/site.webmanifest"/>

        {% include "partials/seo.njk" %}

        {% include "partials/analytics.njk" %}

        {# risotto theme CSS (ported) #}
        {# Prevent theme "white flash" (FOUC) on navigation #}
        <script src="/assets/js/theme-init.js"></script>
        <noscript>
            <link id="palette-stylesheet" rel="stylesheet" href="/assets/css/palettes/base16-dark.css"/>
        </noscript>
        <link rel="stylesheet" href="/assets/css/risotto.css"/>
        <link rel="stylesheet" href="/assets/css/custom.css"/>
        <link rel="stylesheet" href="/assets/css/about.css"/>
    </head>
    <body>
        <div class="page">
            <header class="page__header">
                {% include "partials/header.njk" %}
            </header>

            <main class="page__body">
                {% block main %}
                    {{ content | safe }}
                {% endblock %}
            </main>

            <section class="page__aside">
                <div class="aside__about">
                    {% include "partials/about.njk" %}
                </div>
                <hr>
                <div class="aside__content">
                    {% block aside %}
                        {% if description %}<p>{{ description }}</p>{% endif %}
                    {% endblock %}
                </div>
            </section>

            <footer class="page__footer">
                {% include "partials/footer.njk" %}
            </footer>
        </div>

        <script src="/assets/js/theme.js" defer></script>
    </body>
</html>
